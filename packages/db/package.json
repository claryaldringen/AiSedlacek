{
  "name": "@ai-sedlacek/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./billing": {
      "types": "./src/billing.ts",
      "default": "./src/billing.ts"
    },
    "./versioning": {
      "types": "./src/versioning.ts",
      "default": "./src/versioning.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format:check": "prettier --check src/",
    "format": "prettier --write src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6"
  },
  "devDependencies": {
    "eslint": "^9",
    "prettier": "^3",
    "prisma": "^6",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
