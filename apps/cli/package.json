{
  "name": "ai-sedlacek-cli",
  "version": "0.1.0",
  "description": "CLI klient pro čtečku starých textů — stahování, úprava a nahrávání historických rukopisů",
  "type": "module",
  "bin": {
    "ais": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format:check": "prettier --check src/",
    "format": "prettier --write src/",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5",
    "cli-table3": "^0.6",
    "commander": "^13",
    "open": "^10",
    "ora": "^8"
  },
  "devDependencies": {
    "eslint": "^9",
    "prettier": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claryaldringen/AiSedlacek.git"
  },
  "license": "MIT",
  "keywords": [
    "ocr",
    "manuscripts",
    "paleography",
    "transcription",
    "cli",
    "ai-sedlacek"
  ]
}
