{
  "name": "@ai-sedlacek/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css}\" --ignore-path ../../.gitignore",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css}\" --ignore-path ../../.gitignore",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sedlacek/shared": "*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "^6",
    "@tailwindcss/typography": "^0.5.19",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "sharp": "^0.33"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9",
    "prettier": "^3",
    "prisma": "^6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
