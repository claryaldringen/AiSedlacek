{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@ai-sedlacek/db": ["../../packages/db/src"],
      "@ai-sedlacek/db/*": ["../../packages/db/src/*"],
      "@ai-sedlacek/shared": ["../../packages/shared/src"],
      "@ai-sedlacek/shared/*": ["../../packages/shared/src/*"],
      "@ai-sedlacek/ocr": ["../../packages/ocr/src"],
      "@ai-sedlacek/ocr/*": ["../../packages/ocr/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
