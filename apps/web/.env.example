# === LLM Provider ===
# Options: "ollama" (default, no API key needed) | "claude" (requires ANTHROPIC_API_KEY)
# If not set, auto-detected: claude if ANTHROPIC_API_KEY is present, otherwise ollama
LLM_PROVIDER=ollama

# === Storage Provider ===
# Options: "local" (default, saves to /tmp) | "vercel-blob" (requires BLOB_READ_WRITE_TOKEN)
# If not set, auto-detected: vercel-blob if BLOB_READ_WRITE_TOKEN is present, otherwise local
STORAGE_PROVIDER=local

# === Ollama (default LLM, runs locally) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava:13b
# Optional timeout in milliseconds (default: 120000)
# OLLAMA_TIMEOUT_MS=120000

# === Anthropic Claude (optional, requires LLM_PROVIDER=claude) ===
# ANTHROPIC_API_KEY=

# === Transkribus OCR (optional) ===
# TRANSKRIBUS_EMAIL=
# TRANSKRIBUS_PASSWORD=
# TRANSKRIBUS_MODEL_ID=

# === Vercel Blob Storage (optional, requires STORAGE_PROVIDER=vercel-blob) ===
# BLOB_READ_WRITE_TOKEN=

# === Tesseract.js configuration ===
TESSERACT_LANG=deu_frak+ces+lat

# === General ===
MAX_FILE_SIZE_MB=20
